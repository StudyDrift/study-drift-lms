# syntax=docker/dockerfile:1
# Development image: [Air](https://github.com/air-verse/air) rebuilds and restarts ./cmd/server on .go changes.
# Used by docker compose -f docker-compose.dev.yml (source is bind-mounted at /app at runtime).
FROM golang:1.23-bookworm
WORKDIR /app

ENV CGO_ENABLED=0
# Pinned: @latest can require a newer Go than the app image; bump when upgrading the base `golang` image.
RUN go install github.com/air-verse/air@v1.61.0

# Warm module cache; full tree comes from the host via bind mount when the container runs.
COPY go.mod go.sum* ./
RUN go mod download

EXPOSE 8080
CMD ["air", "-c", ".air.toml"]
