# Copy to `.env` in this directory for local `cargo run` (loaded by dotenvy).
DATABASE_URL=postgres://studydrift:studydrift@127.0.0.1:5432/studydrift?sslmode=disable
# Must be ≥32 characters. Generate: openssl rand -base64 48
# For throwaway local only: ALLOW_INSECURE_JWT=1 (omit JWT_SECRET) — never in production.
JWT_SECRET=local-dev-replace-with-openssl-rand-base64-48
RUN_MIGRATIONS=true
# OpenRouter (https://openrouter.ai) — image generation + Settings AI model dropdown. Alias: OPEN_ROUTER_API_KEY
OPENROUTER_API_KEY=

# Password reset emails: link base for the web app (no trailing slash). Override in production.
PUBLIC_WEB_ORIGIN=http://localhost:5173
# Optional SMTP — when unset, reset links are logged at INFO for local development.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.edu
