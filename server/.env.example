# Copy to .env and adjust for local development (never commit .env).
#
# Required for the API process:
DATABASE_URL=postgres://studydrift:studydrift@localhost:5432/studydrift?sslmode=disable
JWT_SECRET=change-me-use-at-least-32-characters-for-production

# Optional
PORT=8080
RUN_MIGRATIONS=true
OPENROUTER_API_KEY=
OPEN_ROUTER_API_KEY=
COURSE_FILES_ROOT=data/course-files
PUBLIC_WEB_ORIGIN=http://localhost:5173

# MFA (TOTP + WebAuthn): set MFA_ENABLED=1 to allow enrolment and second factor. Optional MFA_ENFORCEMENT=none|all|staff.
# MFA_ENABLED=0
# MFA_ENFORCEMENT=none

# Magic link (passwordless email): off by default. Set MAGIC_LINK_ENABLED=1 after SMTP is configured.
# MAGIC_LINK_ENABLED=0
# Optional: only send links to users with an active course enrollment.
# MAGIC_LINK_ENROLLED_ONLY=0

# Clever Instant Login (plan 4.4): OAuth redirect uses OIDC_PUBLIC_BASE_URL (or LTI_API_BASE_URL).
# CLEVER_SSO_ENABLED=1
# CLEVER_CLIENT_ID=
# CLEVER_CLIENT_SECRET=
# CLEVER_DISTRICT_ID=

# ClassLink OIDC (plan 4.4): issuer is tenant-specific, e.g. https://launchpad.classlink.com/v2_0/sis/{tenant}
# CLASSLINK_SSO_ENABLED=1
# CLASSLINK_OIDC_ISSUER=
# CLASSLINK_OIDC_CLIENT_ID=
# CLASSLINK_OIDC_CLIENT_SECRET=
