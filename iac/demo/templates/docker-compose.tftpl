# Rendered on the Droplet by Terraform (cloud-init). Images are built and pushed by GitHub Actions.
# Compose reads variables from /opt/lextures/.env at runtime; use $$ in this file for literal dollar signs.

services:
  postgres:
    image: postgres:16-alpine
    labels:
      - "com.centurylinklabs.watchtower.enable=false"
    environment:
      POSTGRES_USER: studydrift
      POSTGRES_PASSWORD: $${POSTGRES_PASSWORD}
      POSTGRES_DB: studydrift
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U studydrift -d studydrift"]
      interval: 5s
      timeout: 5s
      retries: 5

  server:
    image: ${ghcr_image_prefix}/lextures-server:latest
    labels:
      - "com.centurylinklabs.watchtower.enable=true"
    environment:
      RUST_LOG: info
      DATABASE_URL: postgres://studydrift:$${POSTGRES_PASSWORD}@postgres:5432/studydrift?sslmode=disable
      JWT_SECRET: $${JWT_SECRET}
      RUN_MIGRATIONS: "true"
      OPENROUTER_API_KEY: $${OPENROUTER_API_KEY}
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "8080:8080"

  web:
    image: ${ghcr_image_prefix}/lextures-web:latest
    labels:
      - "com.centurylinklabs.watchtower.enable=true"
    depends_on:
      - server
    ports:
      - "80:80"

  watchtower:
    image: containrrr/watchtower:1.7.1
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - WATCHTOWER_CLEANUP=true
      - WATCHTOWER_POLL_INTERVAL=30
      - WATCHTOWER_LABEL_ENABLE=true

volumes:
  postgres_data:
