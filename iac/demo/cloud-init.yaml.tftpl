#cloud-config
# Docker is installed via explicit apt in runcmd (more reliable than the packages module alone).
# After changing this file, recreate the Droplet (or taint + apply) so cloud-init runs again.
package_update: true

write_files:
  - path: /opt/lextures/docker-compose.yml
    permissions: "0644"
    content: |
${indent(6, compose_yaml)}
  - path: /opt/lextures/.env
    permissions: "0600"
    content: |
      POSTGRES_PASSWORD=${postgres_password}
      JWT_SECRET=${jwt_secret}
      OPENROUTER_API_KEY=${openrouter_api_key}
  - path: /opt/lextures/boot.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      cd /opt/lextures
      for _ in $(seq 1 90); do
        if docker compose pull && docker compose up -d; then
          exit 0
        fi
        sleep 20
      done
      exit 1

runcmd:
  # Install Docker Engine + Compose v2 (plugin). Requires universe on Ubuntu; apt-get pulls deps.
  - |
    set -euo pipefail
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y
    apt-get install -y docker.io docker-compose-plugin
    systemctl enable --now docker
    for _ in $(seq 1 60); do
      if docker info >/dev/null 2>&1; then
        break
      fi
      sleep 2
    done
    docker info >/dev/null 2>&1
  - /opt/lextures/boot.sh
