#cloud-config
# Docker: installed via https://get.docker.com (docker-ce + compose plugin). More reliable than
# docker.io from Ubuntu alone (universe / mirror issues on first boot).
#
# user_data runs ONLY on first boot. To apply changes: destroy + recreate the Droplet, or
#   terraform apply -replace='digitalocean_droplet.demo'
package_update: true

write_files:
  - path: /opt/lextures/docker-compose.yml
    permissions: "0644"
    content: |
${indent(6, compose_yaml)}
  - path: /opt/lextures/.env
    permissions: "0600"
    content: |
      POSTGRES_PASSWORD=${postgres_password}
      JWT_SECRET=${jwt_secret}
      OPENROUTER_API_KEY=${openrouter_api_key}
  - path: /opt/lextures/boot.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      cd /opt/lextures
      for _ in $(seq 1 90); do
        if docker compose pull && docker compose up -d; then
          exit 0
        fi
        sleep 20
      done
      exit 1

runcmd:
  - |
    set -euo pipefail
    exec >> /var/log/lextures-docker-install.log 2>&1
    echo "=== lextures docker install $(date -Is) ==="
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y
    apt-get install -y ca-certificates curl
    curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
    sh /tmp/get-docker.sh
    rm -f /tmp/get-docker.sh
    systemctl enable --now docker
    for _ in $(seq 1 60); do
      if docker info >/dev/null 2>&1; then
        break
      fi
      sleep 2
    done
    docker info
  - /opt/lextures/boot.sh
